{
  "rewrites": [
    {
      "source": "/api/iss/:path*",
      "destination": "http://api.open-notify.org/:path*"
    },
    {
      "source": "/api/chat/completions",
      "destination": "https://router.huggingface.co/v1/chat/completions"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
